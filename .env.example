# docker-compose configuration (Stage 12). Copy to `.env` and set real secrets.

# --- PostgreSQL ---
POSTGRES_USER=docxautofill
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=docxautofill

# --- Bootstrap admin account (created on first startup) ---
DOCXAUTOFILL_ADMIN_USERNAME=admin
DOCXAUTOFILL_ADMIN_PASSWORD=change-me-now-please

# Set to true when serving over HTTPS behind nginx.
DOCXAUTOFILL_COOKIE_SECURE=false

# Origins allowed to call the API with credentials (JSON array).
DOCXAUTOFILL_CORS_ORIGINS=["http://localhost:5173"]

# Browser-facing backend URL used by the frontend.
VITE_API_URL=http://localhost:3000
