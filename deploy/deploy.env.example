# Configuration for scripts/release.sh (runs on your workstation).
# Copy to deploy/deploy.env and fill in. deploy/deploy.env is gitignored.

# Docker Hub namespace and image tag to build/push/deploy.
REGISTRY=ishikii
TAG=1.0.0
# The server is amd64; build only that arch for speed.
PLATFORMS=linux/amd64

# SSH access to the target server.
SSH_HOST=185.245.35.13
SSH_KEY=~/.ssh/docxautofill_deploy
REMOTE_DIR=/opt/docxautofill
