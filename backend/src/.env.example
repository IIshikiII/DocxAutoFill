# Backend configuration (Stage 12). Copy to `.env` and adjust.
# All variables use the DOCXAUTOFILL_ prefix.

# --- Database ---
# Local development default is a SQLite file; docker-compose overrides this
# with a PostgreSQL URL. Example Postgres URL:
#   postgresql+psycopg://docxautofill:secret@db:5432/docxautofill
DOCXAUTOFILL_DATABASE_URL=sqlite:///./data/app.db

# --- Bootstrap admin account (created on first startup) ---
DOCXAUTOFILL_ADMIN_USERNAME=admin
DOCXAUTOFILL_ADMIN_PASSWORD=change-me-now-please

# --- Sessions / cookies ---
# Set to true in production (HTTPS behind nginx) so the cookie is Secure-only.
DOCXAUTOFILL_COOKIE_SECURE=false
DOCXAUTOFILL_SESSION_TTL_SECONDS=604800

# --- CORS (must be explicit origins, not "*", because credentials are sent) ---
DOCXAUTOFILL_CORS_ORIGINS=["http://localhost:5173"]
